--
-- ora_listagg.sql: test LISTAGG aggregate 
--
--
CREATE TABLE emp(deptno number, ename varchar2(30), sal number, dob date);
ALTER SESSION SET NLS_DATE_FORMAT='DD-MON-YYYY';
INSERT INTO emp VALUES
  (1, 'KING', 1000, '01-JAN-1960'),
  (1, 'JOHN', 900, '01-JAN-1961'),
  (1, 'PAUL' , 800, '01-JAN-1962'),
  (2, 'DAVID', 700, '01-JAN-1963'),
  (2, 'PETER', 600, '01-JAN-1964'),
  (3, 'MARK', 500, '01-JAN-1965');
  (1, NULL,  NULL, NULL),          -- NULLs mixed into an existing group
  (4, NULL,  NULL, NULL),          -- all-NULL group
  (4, NULL,  NULL, NULL);
ERROR:  syntax error at or near "1"
LINE 1: (1, NULL,  NULL, NULL),          -- NULLs mixed into an exis...
         ^
SELECT deptno,
       listagg(ename, ',' ORDER BY ename) AS employees
FROM emp
GROUP BY deptno
ORDER BY deptno;
 deptno |   employees    
--------+----------------
 1      | JOHN,KING,PAUL
 2      | DAVID,PETER
 3      | MARK
(3 rows)

SELECT deptno,
       listagg(sal, ',' ORDER BY sal) AS employees
FROM emp
GROUP BY deptno
ORDER BY deptno;
 deptno |  employees   
--------+--------------
 1      | 800,900,1000
 2      | 600,700
 3      | 500
(3 rows)

SELECT deptno,
       listagg(dob, ',' ORDER BY dob) AS employees
FROM emp
GROUP BY deptno
ORDER BY deptno;
 deptno |              employees              
--------+-------------------------------------
 1      | 01-JAN-1960,01-JAN-1961,01-JAN-1962
 2      | 01-JAN-1963,01-JAN-1964
 3      | 01-JAN-1965
(3 rows)

SELECT deptno,
       listagg(ename, NULL ORDER BY ename) AS employees
FROM emp
GROUP BY deptno
ORDER BY deptno;
 deptno |  employees   
--------+--------------
 1      | JOHNKINGPAUL
 2      | DAVIDPETER
 3      | MARK
(3 rows)

SELECT deptno,
       listagg(NULL::varchar2, ',' ORDER BY ename) AS employees
FROM emp
GROUP BY deptno
ORDER BY deptno;
 deptno | employees 
--------+-----------
 1      | 
 2      | 
 3      | 
(3 rows)

-- NULL rows are skipped; mixed group still produces output
SELECT deptno,
       listagg(ename, ',' ORDER BY ename) AS employees
FROM emp
WHERE deptno IN (1, 4)
GROUP BY deptno
ORDER BY deptno;
 deptno |   employees    
--------+----------------
 1      | JOHN,KING,PAUL
(1 row)

